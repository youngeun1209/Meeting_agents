#!/bin/bash
# App executable. Resolves the project folder (the directory that contains this
# .app), makes Homebrew tools visible (Finder-launched apps get a bare PATH),
# then hands off to the setup wizard, which installs anything missing and opens
# the real GUI.
HERE="$(cd "$(dirname "$0")" && pwd)"          # .../Meeting STT.app/Contents/MacOS
ROOT="$(cd "$HERE/../../.." && pwd)"           # the folder holding the .app
cd "$ROOT"

# GUI-launched apps inherit only /usr/bin:/bin — add the common tool locations
# so swiftc / brew / ollama are found the same as in a real shell.
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

# Pick a python3 that actually has Tkinter — the setup window (and the GUI's
# customtkinter) need it. Homebrew's python often ships WITHOUT _tkinter, so it
# is tried last; python.org / system builds include it.
PY=""
for cand in \
    /usr/local/bin/python3 \
    /Library/Frameworks/Python.framework/Versions/*/bin/python3 \
    /usr/bin/python3 \
    python3 \
    /opt/homebrew/bin/python3; do
    command -v "$cand" >/dev/null 2>&1 || continue
    if "$cand" -c 'import tkinter' >/dev/null 2>&1; then PY="$cand"; break; fi
done

if [ -z "$PY" ]; then
    osascript -e 'display alert "No Python with Tk found" message "Install Python 3 from https://www.python.org/downloads/ (it includes Tkinter), then open Meeting STT again. If you use Homebrew Python, run: brew install python-tk"'
    exit 1
fi

exec "$PY" "$ROOT/setup_app.py"
